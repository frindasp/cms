generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model WebhookEmail {
  id        String   @id @default(cuid())
  from      String?
  to        String?
  subject   String?
  text      String?  @db.Text
  html      String?  @db.Text
  rawData   Json?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String
  password  String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @relation(fields: [roleId], references: [id])

  @@index([roleId], map: "User_roleId_fkey")
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  senderId  String
  senderName String?
  channelId String   // Use email or unique room as channelId
  senderRole String   @default("user") // "user" or "admin"
  createdAt DateTime @default(now())

  @@index([channelId])
  @@index([senderId])
}
