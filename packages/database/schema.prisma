generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}



model ConversationReadState {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  isRead         Boolean  @default(true)
  isArchived     Boolean  @default(false)
  isFavorite     Boolean  @default(false)
  isMuted        Boolean  @default(false)
  isPinned       Boolean  @default(false)

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model WebhookEmail {
  id        String   @id @default(cuid())
  from      String?
  to        String?
  subject   String?
  text      String?  @db.Text
  html      String?  @db.Text
  rawData   Json?
  createdAt DateTime @default(now())
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model User {
  id                  String                @id @default(cuid())
  name                String?
  email               String
  password            String
  roleId              String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  twoFactorEnabled    Boolean               @default(false)
  mfaDismissedAt      DateTime?
  Authenticator       Authenticator[]
  HistoryActivityUser HistoryActivityUser[]
  messages            Message[]
  TotpAuthenticator   TotpAuthenticator[]
  role                Role                  @relation(fields: [roleId], references: [id])
  readStates          ConversationReadState[]

  @@unique([email, roleId])
  @@index([roleId], map: "User_roleId_fkey")
}

model Conversation {
  id         String    @id @default(cuid())
  email      String
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  roleId     String?
  title      String?
  adminAlias String?
  userAlias  String?
  messages   Message[]
  readStates ConversationReadState[]
}

model Message {
  id             String        @id @default(cuid())
  content        String        @db.Text
  senderId       String?
  createdAt      DateTime      @default(now())

  isAdmin        Boolean       @default(false)
  senderEmail    String?
  conversationId String?
  isRead         Boolean       @default(false)

  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  user           User?         @relation(fields: [senderId], references: [id])


  @@index([senderId], map: "Message_senderId_fkey")
  @@index([conversationId], map: "Message_conversationId_fkey")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Authenticator {
  id                   String  @id
  credentialID         String  @unique
  userId               String
  publicKey            Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  enabled              Boolean @default(true)
  User                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HistoryActivityUser {
  id          String   @id
  userId      String?
  action      String
  description String?  @db.Text
  route       String?
  method      String?
  ipAddress   String?
  deviceType  String?
  userAgent   String?
  location    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model TotpAuthenticator {
  id            String   @id
  userId        String
  secret        String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  name          String   @default("Authenticator")
  setupComplete Boolean  @default(false)
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model About {
  id        String   @id @default(cuid())
  content   String   @db.LongText
  email     String
  location  String   @default("Jakarta, Indonesia")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Skill {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  experiences Experience[]
}

model Experience {
  id          String            @id @default(cuid())
  company     String
  role        String
  type        String
  startDate   String
  endDate     String?
  location    String
  skills      Skill[]
  description Json
  images      ExperienceImage[]
  portfolios  Portfolio[]
  order       Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ExperienceImage {
  id              String           @id @default(cuid())
  url             String
  fileId          String?          // Nullable for URL source
  source          String           @default("imagekit") // "imagekit" or "url"
  isLogo          Boolean          @default(false)
  caption         String?
  order           Int              @default(0)
  experienceId    String
  experience      Experience       @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  portfolioImages PortfolioImage[]
  createdAt       DateTime         @default(now())

  @@index([experienceId])
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  portfolios Portfolio[]
  createdAt  DateTime    @default(now())
}

model PortfolioImage {
  id                String           @id @default(cuid())
  url               String
  fileId            String?
  source            String           @default("imagekit") // "imagekit" or "url"
  isLogo            Boolean          @default(false)
  order             Int              @default(0)
  portfolioId       String
  portfolio         Portfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  experienceImageId String?
  experienceImage   ExperienceImage? @relation(fields: [experienceImageId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())

  @@index([portfolioId])
}

model Portfolio {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  images       PortfolioImage[]
  tags         Tag[]
  experienceId String?
  experience   Experience?      @relation(fields: [experienceId], references: [id], onDelete: SetNull)
  order        Int              @default(0)
  isPublished  Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([experienceId])
}

